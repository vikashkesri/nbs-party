<hr data-start="811" data-end="814">
<h1 data-section-id="oquccq" data-start="816" data-end="831">Main Features</h1>
<h2 data-section-id="q1hwdg" data-start="833" data-end="854">1. Public Visitors</h2>
<p data-start="855" data-end="866">Anyone can:</p>
<ul data-start="867" data-end="935">
<li data-section-id="14f48gh" data-start="867" data-end="879">
<p data-start="869" data-end="879">Read posts</p>
</li>
<li data-section-id="2n0fv1" data-start="880" data-end="894">
<p data-start="882" data-end="894">View gallery</p>
</li>
<li data-section-id="1yc4sup" data-start="895" data-end="915">
<p data-start="897" data-end="915">Read public issues</p>
</li>
<li data-section-id="123fyol" data-start="916" data-end="935">
<p data-start="918" data-end="935">Fill Join Us form</p>
</li>
</ul>
<p data-start="937" data-end="955">No login required.</p>
<hr data-start="957" data-end="960">
<h1 data-section-id="tvkov3" data-start="962" data-end="988">2. Authentication System</h1>
<p data-start="990" data-end="1000">Users can:</p>
<ul data-start="1001" data-end="1028">
<li data-section-id="nihrvl" data-start="1001" data-end="1011">
<p data-start="1003" data-end="1011">Register</p>
</li>
<li data-section-id="16r631n" data-start="1012" data-end="1019">
<p data-start="1014" data-end="1019">Login</p>
</li>
<li data-section-id="1pbfm9u" data-start="1020" data-end="1028">
<p data-start="1022" data-end="1028">Logout</p>
</li>
</ul>
<p data-start="1030" data-end="1036">Roles:</p>
<ul data-start="1037" data-end="1051">
<li data-section-id="1j4hu8p" data-start="1037" data-end="1043">
<p data-start="1039" data-end="1043">User</p>
</li>
<li data-section-id="16yus7b" data-start="1044" data-end="1051">
<p data-start="1046" data-end="1051">Admin</p>
</li>
</ul>
<hr data-start="1053" data-end="1056">
<h1 data-section-id="c56okp" data-start="1058" data-end="1075">3. Join Us Form</h1>
<p data-start="1077" data-end="1095">People can submit:</p>

="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼs ͼ16"><div class="cm-scroller"><pre class="cm-content q9tKkq_readonly m-0"><code><span>{</span><br><span>  "name": </span><span class="ͼz">"backend"</span><span>,</span><br><span>  "version": </span><span class="ͼz">"1.0.0"</span><span>,</span><br><span>  "description": </span><span class="ͼz">"Bihar Naujawan Sabha Backend"</span><span>,</span><br><span>  "main": </span><span class="ͼz">"server.js"</span><span>,</span><br><span>  "type": </span><span class="ͼz">"module"</span><span>,</span><br><br><span>  "scripts": {</span><br><span>    "dev": </span><span class="ͼz">"nodemon server.js"</span><span>,</span><br><span>    "start": </span><span class="ͼz">"node server.js"</span><br><span>  },</span><br><br><span>  "keywords": [],</span><br><span>  "author": </span><span class="ͼz">"Vikash"</span><span>,</span><br><span>  "license": </span><span class="ͼz">"ISC"</span><span>,</span><br><br><span>  "dependencies": {</span><br><span>    "bcryptjs": </span><span class="ͼz">"^3.0.3"</span><span>,</span><br><span>    "cloudinary": </span><span class="ͼz">"^2.10.0"</span><span>,</span><br><span>    "cookie-parser": </span><span class="ͼz">"^1.4.7"</span><span>,</span><br><span>    "cors": </span><span class="ͼz">"^2.8.6"</span><span>,</span><br><span>    "dotenv": </span><span class="ͼz">"^17.4.2"</span><span>,</span><br><span>    "express": </span><span class="ͼz">"^5.2.1"</span><span>,</span><br><span>    "jsonwebtoken": </span><span class="ͼz">"^9.0.3"</span><span>,</span><br><span>    "mongoose": </span><span class="ͼz">"^9.6.2"</span><span>,</span><br><span>    "multer": </span><span class="ͼz">"^2.1.1"</span><br><span>  },</span><br><br><span>  "devDependencies": {</span><br><span>    "nodemon": </span><span class="ͼz">"^3.1.14"</span><br><span>  }</span><br><span>}</span></code></pre></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
